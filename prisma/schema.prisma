generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  currency      String   @default("INR")
  cashInBank    Decimal  @default(0) @db.Decimal(15, 2)
  gstNumber     String?
  address       String?  @db.Text
  logoUrl       String?
  alertSettings String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users      User[]
  clients    Client[]
  invoices   Invoice[]
  expenses   Expense[]
  revenues   Revenue[]
  accounts   Account[]
  categories ExpenseCategory[]
  budgets    BudgetThreshold[]
  vendors    Vendor[]
  recurringExpenses RecurringExpense[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  invoices   Invoice[]
  expenses   Expense[]
  revenues   Revenue[]
  accounts   Account[]
  clients    Client[]
  categories         ExpenseCategory[]
  bankAccounts       BankAccount[]
  bankTransactions   BankTransaction[]
  importBatches      ImportBatch[]
  vendors            Vendor[]
  recurringExpenses  RecurringExpense[]
  payments           Payment[]
}

model Account {
  id             String   @id @default(uuid())
  name           String
  type           String   @default("bank")
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  currency       String   @default("INR")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  gstNumber String?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  revenues       Revenue[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String
  status        String   @default("draft")
  issueDate     DateTime @default(now())
  dueDate       DateTime
  subtotal      Decimal  @default(0) @db.Decimal(15, 2)
  taxTotal      Decimal  @default(0) @db.Decimal(15, 2)
  total         Decimal  @default(0) @db.Decimal(15, 2)
  currency      String   @default("INR")
  notes         String?  @db.Text

  gstNumber     String?
  placeOfSupply String?
  isInterState  Boolean  @default(false)

  paidAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id])
  lineItems      InvoiceLineItem[]
  payments       Payment[]
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  gstRate     Decimal  @default(0) @db.Decimal(5, 2)
  cgst        Decimal  @default(0) @db.Decimal(15, 2)
  sgst        Decimal  @default(0) @db.Decimal(15, 2)
  igst        Decimal  @default(0) @db.Decimal(15, 2)
  total       Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]

  @@unique([userId, name])
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("INR")
  date        DateTime @default(now())
  vendor      String?
  receipt     String?
  notes       String?  @db.Text
  isRecurring Boolean  @default(false)
  source      String?
  sourceId    String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  categoryId     String?
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])
  vendorId       String?
  vendorEntity   Vendor?          @relation(fields: [vendorId], references: [id])
  accountId      String?
  account        Account?         @relation(fields: [accountId], references: [id])
}

model Revenue {
  id         String   @id @default(uuid())
  month      DateTime
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("INR")
  type       String   @default("recurring")
  source     String?
  sourceId   String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
}

model BudgetThreshold {
  id             String   @id @default(uuid())
  category       String
  monthlyLimit   Decimal  @db.Decimal(15, 2)
  alertAt        Decimal  @default(0.8) @db.Decimal(3, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id             String   @id @default(uuid())
  name           String
  bankName       String?
  accountNumber  String?
  ifscCode       String?
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  currency       String   @default("INR")
  isActive       Boolean  @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  transactions   BankTransaction[]
}

model BankTransaction {
  id              String   @id @default(uuid())
  date            DateTime
  description     String
  reference       String?
  amount          Decimal  @db.Decimal(15, 2)
  type            String   @default("debit")  // debit | credit
  balance         Decimal? @db.Decimal(15, 2)
  category        String?
  vendor          String?
  notes           String?  @db.Text
  isReconciled    Boolean  @default(false)
  confidence      Decimal? @db.Decimal(3, 2)   // AI categorization confidence 0-1
  source          String   @default("csv")     // csv | ofx | aa | manual
  importBatchId   String?
  matchedExpenseId String?
  matchedInvoiceId String?
  hash            String?  @unique            // dedup hash
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccountId  String
  bankAccount    BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id])
}

model ImportBatch {
  id            String   @id @default(uuid())
  type          String            // bank_csv | expense_csv | revenue_csv | financial_statement
  fileName      String
  rowCount      Int      @default(0)
  status        String   @default("pending")  // pending | processing | completed | failed
  errorMessage  String?  @db.Text
  columnMapping String?  @db.Text  // JSON string of column mappings
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  BankTransaction[]
}

model Payment {
  id            String   @id @default(uuid())
  amount        Decimal  @db.Decimal(15, 2)
  date          DateTime @default(now())
  method        String   @default("bank_transfer") // bank_transfer | upi | cash | cheque | card
  reference     String?                            // UTR, UPI ref, cheque number
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id            String   @id @default(uuid())
  name          String
  email         String?
  phone         String?
  company       String?
  gstNumber     String?
  panNumber     String?
  bankName      String?
  bankAccount   String?
  bankIfsc      String?
  paymentTerms  Int      @default(30)  // days
  address       String?  @db.Text
  notes         String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]

  @@unique([userId, name])
}

model RecurringExpense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("INR")
  frequency   String   @default("monthly") // monthly | quarterly | yearly | weekly
  startDate   DateTime @default(now())
  endDate     DateTime?
  nextDueDate DateTime
  lastCreated DateTime?
  isActive    Boolean  @default(true)
  vendor      String?
  categoryId  String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}
